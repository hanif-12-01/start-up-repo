# Database connection
DATABASE_URL="postgresql://username:password@host:port/database"
DIRECT_URL="postgresql://username:password@host:port/database"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# Google AdSense Free-Only Configuration
NEXT_PUBLIC_ENABLE_ADSENSE=false
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_DASHBOARD_SLOT=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_REPORT_SLOT=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_RECOMMENDATION_SLOT=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_PRICING_SLOT=xxxxxxxxxx

# Demo Safe Mode Configuration
DEMO_MODE=false

