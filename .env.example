# Supabase PostgreSQL — Prisma
# Get connection strings from: Supabase Dashboard → Connect → ORM → Prisma
# If password has special chars, URL-encode first:
#   node -e "console.log(encodeURIComponent('YOUR_PASSWORD'))"

# Transaction pooler (port 6543) — used for runtime queries
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<ENCODED_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler (port 5432) — used by Prisma migrations (directUrl)
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<ENCODED_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-generated-secret-here"