{
  "model_name": "Gradient Boosting Regression",
  "model_role": "MAIN_MVP_CANDIDATE",
  "fallback_model": "Rule-Based Prediction",
  "baseline_model": "Ridge Regression",
  "target": "next_month_usage_kwh",
  "cost_formula": "predicted_cost_idr = predicted_usage_kwh * avg_tariff_idr_per_kwh",
  "features": [
    "business_type_encoded",
    "month",
    "latest_usage_kwh",
    "previous_usage_kwh",
    "avg_3_month_usage_kwh",
    "avg_6_month_usage_kwh",
    "trend_1_month",
    "trend_3_month",
    "month_sin",
    "month_cos",
    "avg_tariff_idr_per_kwh"
  ],
  "business_type_encoding": {
    "LAUNDRY": 0,
    "FNB": 1,
    "RETAIL": 2,
    "MANUFACTURE": 3,
    "COLD_STORAGE": 4,
    "OTHER": 6
  },
  "hyperparameters": {
    "n_estimators": 200,
    "learning_rate": 0.05,
    "max_depth": 3,
    "random_state": 42
  },
  "training_data": {
    "source_dir": "ML/final_umkm",
    "usage_range_kwh": [100, 5000],
    "excluded_business_types": ["HOUSEHOLD"],
    "other_cap_rows": 2500,
    "split_strategy": "group-wise time-aware per business_id (70/15/15)"
  },
  "metrics": {
    "mae_usage_kwh": 154.0368,
    "rmse_usage_kwh": 370.7435,
    "mape_usage_percent": 14.4312,
    "smape_usage_percent": 11.4726,
    "wmape_usage_percent": 14.1881
  },
  "artifact_files": {
    "model_pickle": "best_model.pkl",
    "feature_importance": "feature_importance.csv",
    "predictions": "gradient_boosting_predictions.csv",
    "metrics": "gradient_boosting_metrics.csv"
  },
  "disclaimer": "Hasil ini adalah estimasi, bukan tagihan resmi PLN."
}
