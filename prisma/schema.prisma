datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BusinessType {
  LAUNDRY
  FNB
  RETAIL
  MANUFACTURE
  COLD_STORAGE
  OTHER
}

enum UsageStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ReportStatus {
  DRAFT
  GENERATED
  SENT
  ARCHIVED
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  name       String?
  password   String
  businesses Business[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Business {
  id                 String             @id @default(uuid())
  name               String
  type               BusinessType
  address            String?
  powerVA            Int?
  operatingHours     String?
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  electricityEntries ElectricityEntry[]
  dailyUsages        DailyUsage[]
  appliances         Appliance[]
  analysisResults    AnalysisResult[]
  anomalies          Anomaly[]
  recommendations    Recommendation[]
  monthlyReports     MonthlyReport[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId])
  @@index([type])
}

model DailyUsage {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date       DateTime
  usageKwh   Float
  costIdr    Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, date])
  @@index([businessId])
  @@index([date])
}

model ElectricityEntry {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  usageKwh   Float
  costIdr    Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, year, month])
  @@index([businessId])
  @@index([year, month])
}

model Appliance {
  id              String      @id @default(uuid())
  name            String
  powerWatt       Float
  quantity        Int         @default(1)
  dailyUsageHours Float
  usageStatus     UsageStatus @default(ACTIVE)
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([businessId])
  @@index([usageStatus])
}

model AnalysisResult {
  id              String   @id @default(uuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  totalUsageKwh   Float
  totalCostIdr    Float
  avgDailyKwh     Float?
  carbonKg        Float?
  efficiencyScore Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([businessId, year, month])
  @@index([businessId])
  @@index([year, month])
}

model Anomaly {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  description String
  severity    RiskLevel
  usageKwh    Float?
  expectedKwh Float?
  isResolved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId])
  @@index([severity])
  @@index([isResolved])
}

model Recommendation {
  id                  String                   @id @default(uuid())
  businessId          String
  business            Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title               String
  description         String
  estimatedSavingsIdr Float?
  difficulty          RecommendationDifficulty
  isImplemented       Boolean                  @default(false)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([businessId])
  @@index([difficulty])
}

model AuthAttempt {
  id         String   @id @default(uuid())
  identifier String
  ipAddress  String
  action     String
  success    Boolean
  createdAt  DateTime @default(now())

  @@index([identifier, action, success, createdAt])
  @@index([createdAt])
}

model MonthlyReport {
  id         String       @id @default(uuid())
  businessId String
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  status     ReportStatus @default(DRAFT)
  summary    String?
  pdfUrl     String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([businessId, year, month])
  @@index([businessId])
  @@index([status])
}

model Plan {
  id           String         @id @default(uuid())
  code         String         @unique
  name         String
  description  String?
  priceIdr     Int
  billingCycle String
  features     String[]
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscriptions Subscription[]
  payments     Payment[]
}

model Subscription {
  id         String    @id @default(uuid())
  userId     String
  businessId String?
  planId     String
  status     String
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  plan       Plan      @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([status])
}

model Payment {
  id             String    @id @default(uuid())
  userId         String
  businessId     String?
  planId         String
  planCode       String
  invoiceNo      String    @unique
  amountIdr      Int
  status         String
  method         String?
  virtualAccount String?
  notes          String?
  paidAt         DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  plan           Plan      @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([status])
}
